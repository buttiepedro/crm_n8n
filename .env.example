# ══════════════════════════════════════════════════════════════════════════
#  CRM WhatsApp ↔ n8n — ÚNICO archivo de entorno (raíz del repo)
#
#  Copiar a .env:   cp .env.example .env
#
#  Acá va SOLO lo operativo: contraseña del panel técnico, base de datos,
#  puertos y drivers. TODO lo demás (tokens de WhatsApp, App Secret de Meta,
#  verify token, webhooks hacia n8n, cuentas, API keys, usuarios) se
#  configura desde el PANEL TÉCNICO de la plataforma y vive cifrado en la DB.
# ══════════════════════════════════════════════════════════════════════════

# ── Contraseña del panel técnico (REQUERIDA) ───────────────────────────────
# Requisito del proyecto: ni siquiera un admin logueado entra al panel sin
# esta contraseña. Generar una fuerte:  openssl rand -base64 18
ADMIN_PANEL_PASSWORD=

# ── Clave de cifrado (REQUERIDA) ───────────────────────────────────────────
# AES-256-GCM para credenciales guardadas en DB. 32 bytes en base64:
#   openssl rand -base64 32
# ⚠ Si se pierde, los tokens guardados quedan irrecuperables.
CREDENTIALS_ENCRYPTION_KEY=

# ── PostgreSQL (docker compose) ────────────────────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm            # ⚠ cambiar en producción ANTES del primer up
POSTGRES_DB=crm

# ── Puertos expuestos (únicos dos) ─────────────────────────────────────────
WEB_PORT=8000                    # frontend (nginx, proxy /api al backend)
API_PORT=8001                    # API directa: hooks de n8n y webhook de Meta

# ── Entorno ────────────────────────────────────────────────────────────────
APP_ENV=production               # development | staging | production
LOG_LEVEL=INFO
# true si el front se sirve detrás de HTTPS (cookies Secure)
COOKIE_SECURE=false
# Duración de sesión y del desbloqueo del panel técnico
SESSION_TTL_HOURS=12
CONFIG_PANEL_TTL_MINUTES=15

# ── Base de datos para correr el backend SIN Docker ────────────────────────
# (con docker compose se sobreescribe sola hacia el servicio interno `db`)
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm

# ── Drivers de infraestructura ─────────────────────────────────────────────
QUEUE_DRIVER=inline              # inline | cloud_tasks (GCP, fase P5)
STORAGE_DRIVER=local             # local | gcs (GCP, fase P5)
STORAGE_LOCAL_PATH=./storage

# ── Solo para el seed de desarrollo (opcional) ─────────────────────────────
# Base de la URL del webhook n8n de la cuenta de PRUEBA que crea el seed.
# Las cuentas reales se configuran desde el panel técnico.
# N8N_WEBHOOK_BASE=https://n8n.tudominio.com
