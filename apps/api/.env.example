# ══════════════════════════════════════════════════════════════════════════
#  CRM WhatsApp ↔ n8n — Variables de entorno del backend
#
#  Copiar a .env y completar:   cp .env.example .env
#  Todas se validan al arranque (pydantic-settings): si falta una requerida
#  o tiene formato inválido, el proceso NO inicia y el error dice cuál es.
#  En producción los secretos vienen de Google Secret Manager, no de un .env.
# ══════════════════════════════════════════════════════════════════════════

# ── Entorno ────────────────────────────────────────────────────────────────
# development | staging | production  (production desactiva /api/docs)
APP_ENV=development
PORT=8080
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Base de datos (REQUERIDA) ──────────────────────────────────────────────
# Esquema obligatorio: postgresql+asyncpg://usuario:password@host:puerto/db
# · Con docker compose NO hace falta tocarla: el compose la sobreescribe
#   para apuntar al servicio interno `db`.
# · Backend local sin Docker: postgresql+asyncpg://crm:crm@localhost:5432/crm
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm

# ── Secretos de plataforma (REQUERIDOS) ────────────────────────────────────
# Firma de cookies de sesión (P3). Generar:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Contraseña EXPLÍCITA del panel de configuración (requisito del proyecto):
# ni siquiera un admin logueado entra al panel sin ella. Usar una fuerte.
ADMIN_PANEL_PASSWORD=

# Clave maestra AES-256-GCM que cifra las credenciales de WhatsApp y los
# secretos de webhooks en la DB. 32 bytes codificados en base64. Generar:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# ⚠ Si se pierde, los tokens guardados quedan irrecuperables (habrá que
#   recargarlos). No rotar sin el procedimiento del roadmap de seguridad.
CREDENTIALS_ENCRYPTION_KEY=

# ── WhatsApp Business Cloud API (Meta) (REQUERIDOS) ────────────────────────
# Token arbitrario que vos elegís y también pegás en la configuración del
# webhook de la app de Meta (verificación del handshake GET). Generar:
#   python -c "import secrets;print(secrets.token_urlsafe(24))"
WHATSAPP_VERIFY_TOKEN=

# App Secret de la app de Meta (Meta for Developers → App → App settings →
# Basic → App secret). Valida la firma X-Hub-Signature-256 de cada webhook.
WHATSAPP_APP_SECRET=

# Versión de la Graph API (una sola en todo el sistema)
GRAPH_API_VERSION=v21.0

# ── n8n (servicio EXTERNO al stack) ────────────────────────────────────────
# Base de la URL del webhook de n8n que usa el seed para la cuenta de prueba.
# La URL definitiva se gestiona POR CUENTA (panel de configuración, P4).
# ⚠ Desde dentro de Docker, "localhost" no es tu máquina:
#   · n8n corriendo en tu host  → http://host.docker.internal:5678
#   · n8n en la nube            → https://n8n.tudominio.com
N8N_WEBHOOK_BASE=http://host.docker.internal:5678

# ── Infraestructura ────────────────────────────────────────────────────────
# Cola de tareas:  inline (dev/single-instance) | cloud_tasks (GCP, fase P5)
QUEUE_DRIVER=inline

# Adjuntos:  local (disco/volumen) | gcs (Cloud Storage, fase P5)
STORAGE_DRIVER=local
# Ruta del driver local (en docker compose se monta un volumen acá)
STORAGE_LOCAL_PATH=./storage

# ── Google Cloud (solo con drivers gcs/cloud_tasks, fase P5) ───────────────
# GCS_BUCKET_ATTACHMENTS=crm-n8n-adjuntos
# GCP_PROJECT_ID=mi-proyecto-gcp
