# ── Entorno ──────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
PORT=8080
LOG_LEVEL=INFO

# ── Base de datos (PostgreSQL, driver asyncpg) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm

# ── Secretos de plataforma (en prod vienen de Secret Manager) ────────────
SESSION_SECRET=cambiar-por-valor-aleatorio-largo
# Contraseña explícita del panel de configuración (requisito del proyecto)
ADMIN_PANEL_PASSWORD=cambiar-por-contraseña-fuerte
# Clave maestra AES-256-GCM: 32 bytes en base64.
# Generar con:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
CREDENTIALS_ENCRYPTION_KEY=

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────
# Token arbitrario que pones también en la config del webhook en Meta
WHATSAPP_VERIFY_TOKEN=cambiar-por-token-aleatorio
# App Secret de la app de Meta (valida X-Hub-Signature-256)
WHATSAPP_APP_SECRET=cambiar-por-app-secret
GRAPH_API_VERSION=v21.0

# ── Infraestructura (drivers locales en dev; GCP en prod) ────────────────
QUEUE_DRIVER=inline            # inline | cloud_tasks (P5)
STORAGE_DRIVER=local           # local | gcs (P5)
STORAGE_LOCAL_PATH=./storage
# GCS_BUCKET_ATTACHMENTS=
# GCP_PROJECT_ID=
